# ── LLM (OpenRouter) ────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Robustheit der LLM-Calls (Defaults in backend/llm.py):
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=2
# LLM_MAX_CONCURRENCY=16

# Fallback-Modelle (OpenRouter Model-Routing, kommagetrennt): fällt das
# primäre Modell aus (Ausfall/Drosselung), routet OpenRouter denselben
# Request automatisch ans nächste Modell — Lernende können weiterarbeiten.
# Gleiche Preisklasse wählen und Kandidaten VOR dem Rollout per
# Tutor-Eval-Vergleich prüfen (scripts/evaluate_tutor_responses.py):
# OPENROUTER_FALLBACK_MODELS=openai/gpt-4.1
OPENROUTER_FALLBACK_MODELS=

# Prompt-Caching für den Chat-System-Prompt (Anthropic cache_control via
# OpenRouter; Folge-Turns zahlen für den Case-Kontext nur ~10 % Input).
# Default an; nur zum Debuggen abschalten:
# LLM_PROMPT_CACHING=1

# ── Auth ────────────────────────────────────────────────────────────
# Shared-Secret, das das Backend als X-API-Key auf /dashboard/* und den
# schreibenden /admin-Endpunkten verlangt. Erzeugen mit:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUSS identisch in frontend/.env.local (TOADAPT_API_KEY) gesetzt sein.
TOADAPT_API_KEY=

# Kohorten-Zugangscode für den Studierenden-Flow (Sessions/Chat/Submissions).
# Leer = offen (nur für Entwicklung/anonyme Experimente). In Produktion
# SETZEN, sonst kann jeder im Internet LLM-Kosten auslösen.
STUDENT_ACCESS_CODE=

# Pseudonymisierung der Teilnehmer-Kennungen (HMAC-Secret). In Produktion
# PFLICHT — ohne wird die eingegebene ID roh gespeichert/geloggt.
# Erzeugen: python -c "import secrets; print(secrets.token_urlsafe(32))"
PSEUDONYM_SECRET=

# Gruppencode-Validierung beim Login (Kurs-Schema G1–Gn): mit z.B. 360 sind
# genau G1–G360 gültig — Tippfehler ('G520', Freitext) werden beim Login
# abgefangen statt als Phantom-Gruppen im Tutor-Dashboard zu landen.
# Leer/0 = Validierung aus (Default; für Prolific-Läufe so lassen).
GROUP_CODE_MAX=

# Forschungs-Key für Einzelpersonen-Endpunkte (/dashboard/students,
# /dashboard/student/*, /dashboard/difficulties) via Header X-Research-Key.
# BEWUSST getrennt vom TOADAPT_API_KEY: Tutor:innen (Teacher-Proxy) sehen
# nur Gruppen-Aggregate. Fail-closed (leer = Endpunkte liefern 503).
RESEARCH_API_KEY=

# Tutor-Einzelcodes leben im FRONTEND (Vercel bzw. frontend/.env.local):
#   TEACHER_ACCESS_CODES = JSON {"kennung":"code",...}
#   Erzeugen mit: python scripts/generate_tutor_codes.py --count 40
# (TEACHER_ACCESS_CODE als Einzelcode-Fallback bleibt unterstützt.)
#
# TEACHER_ARCHIVE_CODE (FRONTEND): Master-Code, mit dem NUR der Master-Tutor
# Cases archivieren darf (Schutz vor versehentlichem, unwiderruflichem
# Entfernen). Fail-closed: leer/ungesetzt = Archivieren gesperrt. Beispiel:
#   TEACHER_ARCHIVE_CODE=000

# ── CORS ────────────────────────────────────────────────────────────
# Kommagetrennte Liste erlaubter Origins in Produktion, z.B.:
#   ALLOWED_ORIGINS=https://toadapt.example.com
# Leer = Entwicklungs-Default (localhost:3000).
ALLOWED_ORIGINS=

# ── MongoDB (primärer Store für Sessions/Submissions/Dashboard) ─────
# Entweder MONGODB_URI ODER die MAS_*/HOST-Kombination setzen.
# Ohne Mongo fällt alles auf In-Memory/Dateien zurück — nur für Entwicklung
# geeignet (Railway-Dateisystem ist ephemer, Daten weg bei jedem Redeploy).
# MONGODB_URI=
MONGODB_MAS_NAME=
MONGODB_MAS_KEY=
MONGODB_HOST=
MONGODB_DATABASE=toadapt
MONGODB_COLLECTION=experiment_events
# MONGODB_SUBMISSIONS_COLLECTION=submission_states
# MONGODB_SESSIONS_COLLECTION=sessions
# MONGODB_DASHBOARD_COLLECTION=dashboard_results

# ── Betrieb / Observability ─────────────────────────────────────────
ENVIRONMENT=development          # "development" | "production" (production = JSON-Logs)
LOG_LEVEL=INFO
# Error-Tracking (leer = deaktiviert):
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# Uvicorn-Worker auf Railway. >1 nur mit konfiguriertem MongoDB!
# WEB_CONCURRENCY=1

# ── TP-Zeitplan (ISO-Daten) ─────────────────────────────────────────
TP1_START=2026-09-14
TP1_DEADLINE=2026-10-05
TP2_START=2026-10-06
TP2_DEADLINE=2026-10-26
TP3_START=2026-10-27
TP3_DEADLINE=2026-11-16
TP4_START=2026-11-17
TP4_DEADLINE=2026-12-07
