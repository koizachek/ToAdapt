# ── LLM (OpenRouter) ────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Auth ────────────────────────────────────────────────────────────
# Shared-Secret, das das Backend als X-API-Key auf /dashboard/* und den
# schreibenden /admin-Endpunkten verlangt. Erzeugen mit:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUSS identisch in frontend/.env.local (TOADAPT_API_KEY) gesetzt sein.
TOADAPT_API_KEY=

# App-Secret (Sessions/Signaturen). Zufälligen 32-Byte-Wert verwenden.
SECRET_KEY=

# ── CORS ────────────────────────────────────────────────────────────
# Kommagetrennte Liste erlaubter Origins in Produktion, z.B.:
#   ALLOWED_ORIGINS=https://toadapt.example.com
# Leer = Entwicklungs-Default (localhost:3000).
ALLOWED_ORIGINS=

# ── MongoDB (optionales Logging + Submission-Store) ─────────────────
# Entweder MONGODB_URI ODER die MAS_*/HOST-Kombination setzen.
# MONGODB_URI=
MONGODB_MAS_NAME=
MONGODB_MAS_KEY=
MONGODB_HOST=
MONGODB_DATABASE=toadapt
MONGODB_COLLECTION=experiment_events

# ── Weitere Infrastruktur ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/toadapt
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

ENVIRONMENT=development          # "development" | "production"
LOG_LEVEL=INFO

# ── TP-Zeitplan (ISO-Daten) ─────────────────────────────────────────
TP1_START=2026-09-14
TP1_DEADLINE=2026-10-05
TP2_START=2026-10-06
TP2_DEADLINE=2026-10-26
TP3_START=2026-10-27
TP3_DEADLINE=2026-11-16
TP4_START=2026-11-17
TP4_DEADLINE=2026-12-07
